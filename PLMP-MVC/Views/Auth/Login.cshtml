@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        height: 100vh;
    }

    .main-wrapper {
        display: flex;
        height: 100vh;
    }

    /* LEFT SIDE */
    .left-side {
        flex: 1;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 60px;
        text-align: center;
    }

    .logo-icon {
        font-size: 60px;
        margin-bottom: 10px;
    }

    .logo {
        font-size: 42px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .subtitle {
        font-size: 18px;
        opacity: 0.9;
        margin-bottom: 25px;
    }

    .desc {
        font-size: 15px;
        line-height: 1.7;
        opacity: 0.9;
        max-width: 400px;
    }

    /* RIGHT SIDE */
    .right-side {
        flex: 1;
        background: white;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .login-card {
        width: 100%;
        max-width: 380px;
    }

    .login-title {
        font-size: 28px;
        font-weight: 800;
        color: #4f46e5;
        margin-bottom: 20px;
        text-align: center;
    }

    .form-control {
        margin-bottom: 15px;
        padding: 12px;
        border-radius: 10px;
        border: 1px solid #ccc;
        width: 100%;
    }

    .btn-login {
        width: 100%;
        background: linear-gradient(to right, #667eea, #764ba2);
        color: white;
        padding: 12px;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-login:hover {
            background: #5a67d8;
        }

    .error-msg {
        color: red;
        margin-bottom: 10px;
        font-size: 14px;
        text-align: center;
    }
</style>

<div class="main-wrapper">

    <!-- LEFT -->
    <div class="left-side">

        <div class="logo-icon">🏢</div>

        <div class="logo">PLMP</div>

        <div class="subtitle">
            Property Leasing & Maintenance Platform
        </div>

        <div class="desc">
            Manage your properties, explore available units, submit maintenance
            requests, and track your contracts easily in one unified platform.
        </div>

    </div>

    <!-- RIGHT -->
    <div class="right-side">

        <div class="login-card">

            <div class="login-title">Login</div>

            @if (ViewBag.Error != null)
            {
                <div class="error-msg">@ViewBag.Error</div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post">

                <input type="text" name="username" class="form-control" placeholder="Email or Username" required />

                <input type="password" name="password" class="form-control" placeholder="Password" required />

                <button type="submit" class="btn-login">Login</button>

            </form>

        </div>

    </div>

</div>