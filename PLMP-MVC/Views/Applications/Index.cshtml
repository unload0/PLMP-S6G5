@* @model IEnumerable<PLMP_S6G5.Models.Application>

@{
    ViewData["Title"] = "Applications";
}

<style>
    .card-box {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .title {
        font-size: 28px;
        font-weight: 800;
        color: #1e3a8a;
        margin-bottom: 20px;
    }

    .btn-approve {
        background: #16a34a;
        color: white;
        border-radius: 8px;
        padding: 6px 12px;
        border: none;
    }

    .btn-reject {
        background: #dc2626;
        color: white;
        border-radius: 8px;
        padding: 6px 12px;
        border: none;
    }

    .success-box {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 15px;
        font-weight: 600;
    }

    .error-box {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 15px;
        font-weight: 600;
    }
</style>

<div class="card-box">
    <h2 class="title">Applications</h2>

    @if (TempData["Success"] != null)
    {
        <div class="success-box">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="error-box">
            @TempData["Error"]
        </div>
    }

    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tenant</th>
                <th>Unit</th>
                <th>Date</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ApplicationId</td>
                    <td>@item.TenantId</td>
                    <td>@item.UnitId</td>
                    <td>@item.ApplicationDate</td>
                    <td>@item.ApplicationStatus</td>
                    <td>
                        @if (item.ApplicationStatus == "Pending")
                        {
                            <form asp-controller="Applications" asp-action="Approve" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ApplicationId" />
                                <button type="submit" class="btn-approve">Approve</button>
                            </form>

                            <form asp-controller="Applications" asp-action="Reject" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ApplicationId" />
                                <button type="submit" class="btn-reject">Reject</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div> *@