@model PLMP_S6G5.Models.Building

@{
    ViewData["Title"] = "Building Details";
}

<style>
    body {
        background: linear-gradient(to right, #667eea, #764ba2);
        font-family: 'Segoe UI';
    }

    .box {
        background: white;
        max-width: 600px;
        margin: 50px auto;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,.2);
    }

    h1 {
        text-align: center;
        margin-bottom: 25px;
    }

    .row-item {
        margin-bottom: 15px;
        font-size: 18px;
    }

    .label {
        font-weight: bold;
        color: #555;
    }

    .btn-custom {
        background: #667eea;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        margin-right: 8px;
    }
</style>

<div class="box">
    <h1>Building Details</h1>

    <div class="row-item"><span class="label">Building ID:</span> @Model.BuildingId</div>
    <div class="row-item"><span class="label">Name:</span> @Model.Name</div>
    <div class="row-item"><span class="label">Address:</span> @Model.Address</div>

    <a asp-action="Edit" asp-route-id="@Model.BuildingId" class="btn-custom">Edit</a>
    <a asp-action="Index" class="btn-custom">Back</a>
</div>