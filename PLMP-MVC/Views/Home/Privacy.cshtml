@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
    body {
        background: linear-gradient(to right, #667eea, #764ba2);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .container-box {
        background-color: white;
        padding: 40px;
        margin-top: 60px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        max-width: 800px;
    }

    h1 {
        text-align: center;
        margin-bottom: 25px;
        color: #333;
    }

    p {
        font-size: 16px;
        color: #555;
        line-height: 1.8;
    }
</style>

<div class="container container-box">
    <h1>🔒 Privacy Policy</h1>

    <p>
        At <strong>PLMP Real Estate Management System</strong>, we are committed to protecting your privacy
        and ensuring the security of your personal data.
    </p>

    <p>
        This system is designed to manage real estate operations including buildings, units, payments,
        and maintenance requests. Any information entered into the system is used strictly for management
        and operational purposes.
    </p>

    <p>
        We do not share your data with third parties. All information is stored securely and accessed only
        by authorized users based on their roles (Admin / User).
    </p>

    <p>
        By using this system, you agree to the collection and use of information in accordance with this policy.
    </p>

    <p>
        If you have any questions regarding this privacy policy, please contact the system administrator.
    </p>
</div>