@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        background: linear-gradient(to right, #667eea, #764ba2);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .container {
        text-align: center;
        color: #000;
        padding: 50px 0;
    }

    .btn-custom {
        background-color: #667eea;
        color: white;
        padding: 12px 20px;
        font-size: 18px;
        border-radius: 8px;
        text-decoration: none;
        margin-top: 30px;
        transition: 0.3s ease;
    }

        .btn-custom:hover {
            background-color: #5563c1;
        }

    h1 {
        font-size: 48px;
        margin-bottom: 20px;
    }

    p {
        font-size: 20px;
    }

    .feature-container {
        margin-top: 50px;
    }

    .feature {
        background-color: white;
        padding: 30px;
        margin-bottom: 20px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        transition: 0.3s ease;
    }

        .feature:hover {
            background-color: #f4f4f4;
        }

        .feature h2 {
            font-size: 24px;
            color: #333;
        }

        .feature p {
            font-size: 16px;
            color: #666;
        }

        .feature .btn-custom {
            background-color: #3498db;
            color: white;
            padding: 10px 18px;
            font-size: 16px;
            border-radius: 8px;
        }

            .feature .btn-custom:hover {
                background-color: #2c80b4;
            }
</style>

<div class="container">
    <h1>Welcome to the Real Estate Management System!</h1>
    <p>Manage your buildings, units, payments, and maintenance requests with ease.</p>

    <div class="feature-container">
        <div class="feature">
            <h2>Manage Buildings</h2>
            <p>View, add, edit, and manage all your buildings in one place.</p>
            <a href="@Url.Action("Index", "Buildings")" class="btn-custom">Explore Buildings</a>
        </div>

        <div class="feature">
            <h2>Manage Units</h2>
            <p>Track all units in your buildings, view details and availability.</p>
            <a href="@Url.Action("Index", "Units")" class="btn-custom">Explore Units</a>
        </div>

        <div class="feature">
            <h2>Manage Payments</h2>
            <p>Stay on top of payments for each unit with detailed tracking.</p>
            <a href="@Url.Action("Index", "Payments")" class="btn-custom">View Payments</a>
        </div>

        <div class="feature">
            <h2>Maintenance Requests</h2>
            <p>Submit and track maintenance requests for your buildings and units.</p>
            <a href="@Url.Action("Index", "MaintenanceRequests")" class="btn-custom">View Maintenance</a>
        </div>
    </div>
</div>