@using PLMP_S6G5.Models

@{
    ViewData["Title"] = "Admin Dashboard";

    var leaseApplications = ViewBag.LeaseApplications as List<Lease>;
    var maintenanceRequests = ViewBag.MaintenanceRequests as List<MaintenanceRequest>;
}

<style>
    .dashboard-title {
        font-size: 34px;
        font-weight: 800;
        color: #312e81;
        margin-bottom: 8px;
    }

    .dashboard-subtitle {
        color: #6b7280;
        margin-bottom: 28px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        border-top: 6px solid #4f46e5;
    }

        .stat-card h3 {
            font-size: 16px;
            color: #6b7280;
            margin-bottom: 8px;
        }

        .stat-card h2 {
            font-size: 32px;
            font-weight: 800;
            color: #312e81;
            margin: 0;
        }

    .section-card {
        background: white;
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        margin-bottom: 30px;
    }

        .section-card h3 {
            margin-bottom: 18px;
            color: #312e81;
            font-size: 24px;
            font-weight: 700;
        }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table th,
        .custom-table td {
            padding: 12px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            font-size: 14px;
        }

        .custom-table th {
            background: #eef2ff;
            color: #312e81;
        }

    .btn-action {
        padding: 8px 14px;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        color: white;
        margin-right: 6px;
    }

    .btn-approve {
        background: #16a34a;
    }

    .btn-reject {
        background: #dc2626;
    }

    .empty-text {
        color: #6b7280;
        font-style: italic;
    }
</style>

<div>
    <h1 class="dashboard-title">Admin Dashboard</h1>
    <p class="dashboard-subtitle">Manage properties, payments, maintenance, and lease applications.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="stats-grid">
    <div class="stat-card">
        <h3>Total Buildings</h3>
        <h2>@ViewBag.Buildings</h2>
    </div>

    <div class="stat-card">
        <h3>Total Units</h3>
        <h2>@ViewBag.Units</h2>
    </div>

    <div class="stat-card">
        <h3>Total Payments</h3>
        <h2>@ViewBag.Payments</h2>
    </div>

    <div class="stat-card">
        <h3>Maintenance Requests</h3>
        <h2>@ViewBag.Requests</h2>
    </div>
</div>

<div class="section-card">
    <h3>Lease Applications</h3>

    @if (leaseApplications == null || !leaseApplications.Any())
    {
        <p class="empty-text">No lease applications available.</p>
    }
    else
    {
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Lease ID</th>
                    <th>Unit ID</th>
                    <th>Tenant ID</th>
                    <th>Manager ID</th>
                    <th>Application Status</th>
                    <th>Lease Status</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lease in leaseApplications)
                {
                    <tr>
                        <td>@lease.LeaseId</td>
                        <td>@lease.UnitId</td>
                        <td>@lease.TenantId</td>
                        <td>@lease.ManagerId</td>
                        <td>@lease.ApplicationStatus</td>
                        <td>@lease.LeaseStatus</td>
                        <td>@lease.StartDate</td>
                        <td>@lease.EndDate</td>
                        <td>
                            @if (lease.ApplicationStatus == "Pending")
                            {
                                <form asp-action="ApproveLease" asp-controller="Home" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@lease.LeaseId" />
                                    <button type="submit" class="btn-action btn-approve">Approve</button>
                                </form>

                                <form asp-action="RejectLease" asp-controller="Home" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@lease.LeaseId" />
                                    <button type="submit" class="btn-action btn-reject">Reject</button>
                                </form>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="section-card">
    <h3>Maintenance Requests</h3>

    @if (maintenanceRequests == null || !maintenanceRequests.Any())
    {
        <p class="empty-text">No maintenance requests available.</p>
    }
    else
    {
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Request ID</th>
                    <th>Tenant ID</th>
                    <th>Category Type</th>
                    <th>Priority</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Staff ID</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in maintenanceRequests)
                {
                    <tr>
                        <td>@request.RequestId</td>
                        <td>@request.TenantId</td>
                        <td>@request.CategoryType</td>
                        <td>@request.Priority</td>
                        <td>@request.Description</td>
                        <td>@request.Status</td>
                        <td>@request.StaffId</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>