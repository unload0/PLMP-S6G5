@model IEnumerable<PLMP_S6G5.Models.Unit>

@{
    ViewData["Title"] = "Units";
}

<style>
    body {
        background: linear-gradient(to right, #667eea, #764ba2);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .container-box {
        background-color: white;
        padding: 30px;
        margin-top: 50px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    h1 {
        text-align: center;
        margin-bottom: 25px;
        color: #333;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .btn-custom {
        background-color: #667eea;
        color: white;
        padding: 8px 14px;
        border-radius: 8px;
        text-decoration: none;
        margin-right: 5px;
    }

        .btn-custom:hover {
            background-color: #5563c1;
            color: white;
        }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #667eea;
        color: white;
        padding: 12px;
        text-align: left;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #ddd;
    }

    tr:hover {
        background-color: #f6f6f6;
    }

    .action-links {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-action {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        color: white;
        transition: 0.3s ease;
    }

    .btn-details {
        background-color: #3498db;
    }

        .btn-details:hover {
            background-color: #2c80b4;
            color: white;
        }

    .btn-edit {
        background-color: #f39c12;
    }

        .btn-edit:hover {
            background-color: #d68910;
            color: white;
        }

    .btn-delete {
        background-color: #e74c3c;
    }

        .btn-delete:hover {
            background-color: #c0392b;
            color: white;
        }
</style>

<div class="container container-box">
    <h1>🏠 Units</h1>

    <div class="top-bar">
        <a asp-action="Create" class="btn-custom">+ Add Unit</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Unit ID</th>
                <th>Building ID</th>
                <th>Type</th>
                <th>Size</th>
                <th>Rent Amount</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.UnitId</td>
                    <td>@item.BuildingId</td>
                    <td>@item.Type</td>
                    <td>@item.Size</td>
                    <td>@item.RentAmount</td>
                    <td>@item.AvailabilityStatus</td>
                    <td class="action-links">
                        <a asp-action="Details" asp-route-id="@item.UnitId" class="btn-action btn-details">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.UnitId" class="btn-action btn-edit">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.UnitId" class="btn-action btn-delete">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>  