@model PLMP_S6G5.Models.Unit

@{
    ViewData["Title"] = "Add Unit";
}

<style>
    .form-card {
        max-width: 700px;
        margin: auto;
        background: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .form-title {
        font-size: 28px;
        font-weight: 800;
        color: #1e3a8a;
        margin-bottom: 20px;
    }

    .btn-main {
        background: #2563eb;
        color: white;
        border-radius: 10px;
        padding: 10px 16px;
        border: none;
    }

    .success-box {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 15px;
        font-weight: 600;
    }

    .error-box {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 15px;
        font-weight: 600;
    }

    .validation-text {
        color: #dc2626;
        font-size: 14px;
        margin-top: 6px;
    }
</style>

<div class="form-card">
    <h2 class="form-title">Add Unit</h2>

    @if (TempData["Success"] != null)
    {
        <div class="success-box">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="error-box">
            @TempData["Error"]
        </div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="validation-text"></div>

        <div class="mb-3">
            <label>Building</label>
            <select asp-for="BuildingId" asp-items="ViewBag.Buildings" class="form-control">
                <option value="">Select Building</option>
            </select>
            <span asp-validation-for="BuildingId" class="validation-text"></span>
        </div>

        <div class="mb-3">
            <label>Type</label>
            <input asp-for="Type" class="form-control" />
            <span asp-validation-for="Type" class="validation-text"></span>
        </div>

        <div class="mb-3">
            <label>Size</label>
            <input asp-for="Size" class="form-control" />
            <span asp-validation-for="Size" class="validation-text"></span>
        </div>

        <div class="mb-3">
            <label>Rent</label>
            <input asp-for="RentAmount" class="form-control" />
            <span asp-validation-for="RentAmount" class="validation-text"></span>
        </div>

        <div class="mb-3">
            <label>Status</label>
            <select asp-for="AvailabilityStatus" class="form-control">
                <option value="Vacant">Vacant</option>
                <option value="Leased">Leased</option>
                <option value="Pending">Pending</option>
            </select>
            <span asp-validation-for="AvailabilityStatus" class="validation-text"></span>
        </div>

        <button type="submit" class="btn-main">Save</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}