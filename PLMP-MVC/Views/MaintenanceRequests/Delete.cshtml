@model PLMP_S6G5.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Delete Maintenance Request";
}

<style>
    body {
        background: linear-gradient(to right, #667eea, #764ba2);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .container-box {
        background-color: white;
        padding: 30px;
        margin-top: 50px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        max-width: 700px;
    }

    h1 {
        text-align: center;
        margin-bottom: 25px;
        color: #c0392b;
    }

    .warning-text {
        text-align: center;
        font-size: 18px;
        margin-bottom: 25px;
        color: #555;
    }

    .details-row {
        margin-bottom: 15px;
        padding: 12px;
        background-color: #f8f9fa;
        border-radius: 8px;
    }

    .details-label {
        font-weight: 700;
        color: #444;
    }

    .btn-delete {
        background-color: #e74c3c;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        border: none;
        margin-right: 8px;
    }

        .btn-delete:hover {
            background-color: #c0392b;
        }

    .btn-custom {
        background-color: #667eea;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        border: none;
        margin-right: 8px;
    }

        .btn-custom:hover {
            background-color: #5563c1;
            color: white;
        }
</style>

<div class="container container-box">
    <h1>🗑 Delete Maintenance Request</h1>

    <p class="warning-text">Are you sure you want to delete this maintenance request?</p>

    <div class="details-row"><span class="details-label">Request ID:</span> @Model.RequestId</div>
    <div class="details-row"><span class="details-label">Tenant ID:</span> @Model.TenantId</div>
    <div class="details-row"><span class="details-label">Staff ID:</span> @Model.StaffId</div>
    <div class="details-row"><span class="details-label">Category:</span> @Model.CategoryType</div>
    <div class="details-row"><span class="details-label">Priority:</span> @Model.Priority</div>
    <div class="details-row"><span class="details-label">Status:</span> @Model.Status</div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="RequestId" />
        <button type="submit" class="btn-delete">Delete</button>
        <a asp-action="Index" class="btn-custom">Back to List</a>
    </form>
</div>