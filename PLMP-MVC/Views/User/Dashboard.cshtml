@using PLMP_S6G5.Models

@{
    ViewData["Title"] = "User Dashboard";

    var availableUnits = ViewBag.AvailableUnits as List<Unit>;
    var myRequests = ViewBag.MyRequests as List<MaintenanceRequest>;
    var myLeases = ViewBag.MyLeases as List<Lease>;
}

<style>
    .dashboard-title {
        font-size: 34px;
        font-weight: 800;
        color: #1e3a8a;
        margin-bottom: 8px;
    }

    .dashboard-subtitle {
        color: #6b7280;
        margin-bottom: 28px;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 20px;
    }

    .dash-card {
        background: #ffffff;
        border-radius: 22px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        border-top: 6px solid #4f46e5;
    }

        .dash-card h3 {
            margin-bottom: 16px;
            color: #312e81;
            font-size: 22px;
            font-weight: 700;
        }

    .mini-table {
        width: 100%;
        border-collapse: collapse;
    }

        .mini-table th, .mini-table td {
            padding: 10px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            font-size: 14px;
        }

        .mini-table th {
            background: #eef2ff;
            color: #312e81;
        }

    .btn-custom {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 10px;
        text-decoration: none;
        color: white;
        font-weight: 600;
        font-size: 13px;
        margin-top: 8px;
        border: none;
    }

    .btn-apply {
        background: #2563eb;
    }

    .btn-request {
        background: #db2777;
    }

    .btn-contract {
        background: #16a34a;
    }

    .empty-text {
        color: #6b7280;
        font-style: italic;
    }
</style>

<div>
    <h1 class="dashboard-title">User Dashboard</h1>
    <p class="dashboard-subtitle">Welcome to your tenant dashboard.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="dashboard-grid">

    <div class="dash-card">
        <h3>Available Units</h3>

        @if (availableUnits == null || !availableUnits.Any())
        {
            <p class="empty-text">No available units at the moment.</p>
        }
        else
        {
            <table class="mini-table">
                <thead>
                    <tr>
                        <th>Unit ID</th>
                        <th>Type</th>
                        <th>Rent</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var unit in availableUnits)
                    {
                        <tr>
                            <td>@unit.UnitId</td>
                            <td>@unit.Type</td>
                            <td>@unit.RentAmount</td>
                            <td>
                                <a asp-controller="User" asp-action="Apply" asp-route-id="@unit.UnitId" class="btn-custom btn-apply">Apply</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="dash-card">
        <h3>My Requests</h3>

        @if (myRequests == null || !myRequests.Any())
        {
            <p class="empty-text">No maintenance requests found.</p>
        }
        else
        {
            <table class="mini-table">
                <thead>
                    <tr>
                        <th>Request ID</th>
                        <th>Category</th>
                        <th>Priority</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in myRequests)
                    {
                        <tr>
                            <td>@request.RequestId</td>
                            <td>@request.CategoryType</td>
                            <td>@request.Priority</td>
                            <td>@request.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <a asp-controller="User" asp-action="CreateMaintenanceRequest" class="btn-custom btn-request">
            Create Maintenance Request
        </a>
    </div>

    <div class="dash-card">
        <h3>My Leases / Contracts</h3>

        @if (myLeases == null || !myLeases.Any())
        {
            <p class="empty-text">No contracts or applications available.</p>
        }
        else
        {
            <table class="mini-table">
                <thead>
                    <tr>
                        <th>Lease ID</th>
                        <th>Unit ID</th>
                        <th>Application Status</th>
                        <th>Lease Status</th>
                        <th>Contract</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lease in myLeases)
                    {
                        <tr>
                            <td>@lease.LeaseId</td>
                            <td>@lease.UnitId</td>
                            <td>@lease.ApplicationStatus</td>
                            <td>@lease.LeaseStatus</td>
                            <td>
                                <a asp-controller="User" asp-action="Contract" asp-route-id="@lease.LeaseId" class="btn-custom btn-contract">
                                    View Contract
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>