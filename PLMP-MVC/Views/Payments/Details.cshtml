@model PLMP_S6G5.Models.Payment

@{
    ViewData["Title"] = "Payment Details";
}

<style>
    body {
        background: linear-gradient(to right, #667eea, #764ba2);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .container-box {
        background-color: white;
        padding: 30px;
        margin-top: 50px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        max-width: 700px;
    }

    h1 {
        text-align: center;
        margin-bottom: 25px;
        color: #333;
    }

    .details-row {
        margin-bottom: 15px;
        padding: 12px;
        background-color: #f8f9fa;
        border-radius: 8px;
    }

    .details-label {
        font-weight: 700;
        color: #444;
    }

    .btn-custom {
        background-color: #667eea;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        border: none;
        margin-right: 8px;
    }

        .btn-custom:hover {
            background-color: #5563c1;
            color: white;
        }
</style>

<div class="container container-box">
    <h1>📄 Payment Details</h1>

    <div class="details-row"><span class="details-label">Payment ID:</span> @Model.PaymentId</div>
    <div class="details-row"><span class="details-label">Lease ID:</span> @Model.LeaseId</div>
    <div class="details-row"><span class="details-label">Installment Amount:</span> @Model.InstallmentAmount</div>
    <div class="details-row"><span class="details-label">Date Of Issue:</span> @Model.DateOfIssue</div>
    <div class="details-row"><span class="details-label">Balance:</span> @Model.Balance</div>
    <div class="details-row"><span class="details-label">Payment Status:</span> @Model.PaymentStatus</div>

    <a asp-action="Edit" asp-route-id="@Model.PaymentId" class="btn-custom">Edit</a>
    <a asp-action="Index" class="btn-custom">Back to List</a>
</div>