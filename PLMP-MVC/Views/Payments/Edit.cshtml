@model PLMP_S6G5.Models.Payment

@{
    ViewData["Title"] = "Edit Payment";
}

<style>
    body {
        background: linear-gradient(to right, #667eea, #764ba2);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .container-box {
        background-color: white;
        padding: 30px;
        margin-top: 50px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        max-width: 700px;
    }

    h1 {
        text-align: center;
        margin-bottom: 25px;
        color: #333;
    }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        color: #333;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #ccc;
        border-radius: 8px;
        font-size: 15px;
    }

    .btn-custom {
        background-color: #667eea;
        color: white;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        border: none;
        margin-right: 8px;
    }

        .btn-custom:hover {
            background-color: #5563c1;
            color: white;
        }

    .text-danger {
        color: #e74c3c;
        font-size: 14px;
    }
</style>

<div class="container container-box">
    <h1>✏️ Edit Payment</h1>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="PaymentId" />

        <div class="form-group">
            <label asp-for="LeaseId"></label>
            <input asp-for="LeaseId" class="form-control" />
            <span asp-validation-for="LeaseId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="InstallmentAmount"></label>
            <input asp-for="InstallmentAmount" class="form-control" />
            <span asp-validation-for="InstallmentAmount" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="DateOfIssue"></label>
            <input asp-for="DateOfIssue" type="date" class="form-control" />
            <span asp-validation-for="DateOfIssue" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Balance"></label>
            <input asp-for="Balance" class="form-control" />
            <span asp-validation-for="Balance" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="PaymentStatus"></label>
            <input asp-for="PaymentStatus" class="form-control" />
            <span asp-validation-for="PaymentStatus" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-custom">Update</button>
        <a asp-action="Index" class="btn-custom">Back to List</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}